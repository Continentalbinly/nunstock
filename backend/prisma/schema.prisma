// Generated by Prisma CLI
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PartCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6366f1")
  icon      String   @default("package")
  parts     Part[]
  createdAt DateTime @default(now())

  @@map("part_categories")
}

model Part {
  id          String          @id @default(cuid())
  code        String          @unique
  name        String
  description String?
  brand       String?
  unit        String          @default("ชิ้น")
  quantity    Int             @default(0)
  minStock    Int             @default(5)
  categoryId  String
  category    PartCategory    @relation(fields: [categoryId], references: [id])
  withdrawals Withdrawal[]
  movements   StockMovement[]
  claimItems  ClaimItem[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("parts")
}

model Withdrawal {
  id        String   @id @default(cuid())
  partId    String
  part      Part     @relation(fields: [partId], references: [id])
  quantity  Int
  reason    String?
  jobNo     String?
  techName  String?
  createdAt DateTime @default(now())

  @@map("withdrawals")
}

model StockMovement {
  id        String       @id @default(cuid())
  partId    String
  part      Part         @relation(fields: [partId], references: [id])
  type      MovementType
  quantity  Int
  reason    String?
  jobNo     String?
  techName  String?
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  createdAt DateTime     @default(now())

  @@map("stock_movements")
}

enum MovementType {
  IN
  OUT
}

model InsuranceClaim {
  id            String      @id @default(cuid())
  claimNo       String      @unique
  customerName  String
  customerPhone String
  carBrand      String
  carModel      String
  plateNo       String
  insuranceComp String
  jobNo         String?
  notes         String?
  status        ClaimStatus @default(PENDING)
  items         ClaimItem[]
  arrivedAt     DateTime?
  notifiedAt    DateTime?
  notifyChannel String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("insurance_claims")
}

model ClaimItem {
  id       String         @id @default(cuid())
  claimId  String
  claim    InsuranceClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  partId   String?
  part     Part?          @relation(fields: [partId], references: [id])
  partName String
  quantity Int

  @@map("claim_items")
}

enum ClaimStatus {
  PENDING
  ORDERED
  ARRIVED
  NOTIFIED
  COMPLETED
}

model User {
  id        String          @id @default(cuid())
  username  String          @unique
  password  String
  name      String
  role      String          @default("admin")
  movements StockMovement[]
  createdAt DateTime        @default(now())

  @@map("users")
}
