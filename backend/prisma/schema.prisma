generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PartType {
  CONSUMABLE
  INSURANCE
  PAINT
}

model LookupOption {
  id        String   @id @default(cuid())
  group     String   // "UNIT" | "SPEC"
  value     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([group, value])
  @@map("lookup_options")
}

model PartCategory {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6366f1")
  icon      String   @default("📦")
  parentId  String?  
  createdAt DateTime @default(now())
  
  parent        PartCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  subCategories PartCategory[] @relation("CategoryHierarchy")
  parts         Part[]

  @@unique([name, parentId])
  @@index([parentId])
  @@map("part_categories")
}

model Part {
  id          String          @id @default(cuid())
  code        String
  name        String
  type        PartType?
  description String?
  brand       String?
  specification String?
  unit        String          @default("ชิ้น")
  quantity    Int             @default(0)
  minStock    Int             @default(5)
  categoryId  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  category    PartCategory?   @relation(fields: [categoryId], references: [id])
  movements   StockMovement[]

  @@index([type])
  @@index([categoryId])
  @@index([name])
  @@index([code])
  @@index([brand])
  @@map("parts")
}


model StockMovement {
  id        String       @id @default(cuid())
  partId    String
  type      MovementType
  quantity  Int
  reason    String?
  jobNo     String?
  techName  String?
  userId    String
  createdAt DateTime     @default(now())
  part      Part         @relation(fields: [partId], references: [id])
  user      User         @relation(fields: [userId], references: [id])

  @@index([type, createdAt])
  @@index([partId])
  @@map("stock_movements")
}



enum UserRole {
  ADMIN
  TECH
}

model User {
  id        String          @id @default(cuid())
  username  String          @unique
  password  String
  name      String
  role      UserRole        @default(ADMIN)
  createdAt DateTime        @default(now())
  movements StockMovement[]
  audits    AuditLog[]

  @@map("users")
}

enum MovementType {
  IN
  OUT
}



enum ShopStockSource {
  EXCESS_ORDER
  CUSTOMER_LEFTOVER
  CLAIM_MISMATCH
  CLAIM_NO_PICKUP
  JOB_CANCEL
}

enum ShopStockCondition {
  USABLE
  NEEDS_REPAIR
  SCRAP
}

enum JobType {
  INSURANCE
  CASH
}

enum JobStatus {
  WAITING_PARTS
  RECEIVED
  IN_PROGRESS
  COMPLETED
  DELIVERED
  CLOSED
  CANCELLED
}

enum JobPartSource {
  SHOP_PART
  INSURANCE_PART
  SHOP_STOCK
  CONSUMABLE
  PAINT
  EXTERNAL
}

enum JobPartStatus {
  ORDERED
  ARRIVED
  WITHDRAWN
  INSTALLED
}

enum RepairStep {
  BODY_REPAIR
  PAINTING
  PARTS_REPLACEMENT
  POLISHING
}

enum RepairStepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model ShopStock {
  id          String             @id @default(cuid())
  name        String
  description String?
  carBrand    String?
  carModel    String?
  quantity    Int                @default(1)
  unit        String             @default("ชิ้น")
  source      ShopStockSource
  sourceRef   String?
  sourceNote  String?
  condition   ShopStockCondition @default(USABLE)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  usages      ShopStockUsage[]

  @@map("shop_stocks")
}

model ShopStockUsage {
  id          String    @id @default(cuid())
  shopStockId String
  quantity    Int
  jobNo       String?
  note        String?
  usedAt      DateTime  @default(now())

  shopStock   ShopStock @relation(fields: [shopStockId], references: [id])

  @@map("shop_stock_usages")
}

model Job {
  id            String          @id @default(cuid())
  jobNo         String          @unique
  type          JobType
  status        JobStatus       @default(WAITING_PARTS)
  customerName  String
  customerPhone String?
  carBrand      String
  carModel      String
  plateNo       String
  notes         String?

  claimNo       String?
  insuranceComp String?
  receivedAt    DateTime        @default(now())
  startedAt     DateTime?
  completedAt   DateTime?
  deliveredAt   DateTime?
  cancelReason  String?
  cancelledAt   DateTime?
  claimCalledAt DateTime?
  closedAt      DateTime?
  lineUserId    String?
  lineLinkedAt  DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt


  parts         JobPart[]
  repairSteps   JobRepairStep[]
  notifications Notification[]
  statusLogs    JobStatusLog[]
  jobNotes      JobNote[]

  @@index([type, status])
  @@index([createdAt])
  @@index([jobNo])
  @@index([customerName])
  @@index([plateNo])
  @@map("jobs")
}

model Notification {
  id        String   @id @default(cuid())
  jobId     String
  type      String   // PARTS_ARRIVED, STATUS_CHANGE, MANUAL
  channel   String   @default("LINE")
  recipient String   // lineUserId or phone
  message   String
  status    String   @default("PENDING") // PENDING, SENT, FAILED
  error     String?
  sentAt    DateTime?
  createdAt DateTime @default(now())

  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model JobRepairStep {
  id      String           @id @default(cuid())
  jobId   String
  step    String           // free text, matches template label
  label   String
  status  RepairStepStatus @default(PENDING)
  order   Int

  job     Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_repair_steps")
}

model RepairStepTemplate {
  id    String @id @default(cuid())
  label String @unique
  icon  String @default("Wrench")
  color String @default("#6B7280")

  @@map("repair_step_templates")
}

model JobPart {
  id          String        @id @default(cuid())
  jobId       String
  source      JobPartSource
  sourceId    String?
  partName    String
  barcode     String?       @unique
  quantity    Int
  unit        String        @default("ชิ้น")
  note        String?
  withdrawnBy String?
  status      JobPartStatus @default(ORDERED)
  addedAt     DateTime      @default(now())

  job         Job           @relation(fields: [jobId], references: [id])

  @@index([source])
  @@index([addedAt])
  @@map("job_parts")
}

model LineRegistration {
  id              String   @id @default(cuid())
  lineUserId      String
  customerName    String
  plateNo         String
  normalizedPlate String
  matched         Boolean  @default(false)

  createdAt       DateTime @default(now())

  @@unique([lineUserId, normalizedPlate])
  @@map("line_registrations")
}


model CarType {
  id     String   @id @default(cuid())
  key    String   @unique
  label  String
  brands String[]
  order  Int      @default(0)

  @@map("car_types")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // CREATE_PART, DELETE_PART, UPDATE_PART, BATCH_OUT, BATCH_IN, etc.
  entity    String   // Part, StockMovement, etc.
  entityId  String?
  details   String?  // JSON details
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model JobStatusLog {
  id         String   @id @default(cuid())
  jobId      String
  job        Job      @relation(fields: [jobId], references: [id])
  fromStatus String
  toStatus   String
  changedBy  String?
  changedAt  DateTime @default(now())
  notes      String?

  @@index([toStatus, changedAt])
  @@map("job_status_logs")
}

model JobNote {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id])
  note      String
  createdBy String?
  createdAt DateTime @default(now())

  @@map("job_notes")
}
