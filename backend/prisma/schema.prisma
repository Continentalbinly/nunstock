generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PartCategory {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6366f1")
  icon      String   @default("📦")
  parentId  String?  
  createdAt DateTime @default(now())
  
  parent        PartCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  subCategories PartCategory[] @relation("CategoryHierarchy")
  parts         Part[]

  @@unique([name, parentId])
  @@map("part_categories")
}

model Part {
  id          String          @id @default(cuid())
  code        String          @unique
  name        String
  description String?
  brand       String?
  unit        String          @default("ชิ้น")
  quantity    Int             @default(0)
  minStock    Int             @default(5)
  categoryId  String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  claimItems  ClaimItem[]
  category    PartCategory    @relation(fields: [categoryId], references: [id])
  movements   StockMovement[]
  withdrawals Withdrawal[]

  @@map("parts")
}

model Withdrawal {
  id        String   @id @default(cuid())
  partId    String
  quantity  Int
  reason    String?
  jobNo     String?
  techName  String?
  createdAt DateTime @default(now())
  part      Part     @relation(fields: [partId], references: [id])

  @@map("withdrawals")
}

model StockMovement {
  id        String       @id @default(cuid())
  partId    String
  type      MovementType
  quantity  Int
  reason    String?
  jobNo     String?
  techName  String?
  userId    String
  createdAt DateTime     @default(now())
  part      Part         @relation(fields: [partId], references: [id])
  user      User         @relation(fields: [userId], references: [id])

  @@map("stock_movements")
}

model InsuranceClaim {
  id            String      @id @default(cuid())
  claimNo       String      @unique
  customerName  String
  customerPhone String
  carBrand      String
  carModel      String
  plateNo       String
  insuranceComp String
  jobNo         String?
  notes         String?
  status        ClaimStatus @default(PENDING)
  arrivedAt     DateTime?
  notifiedAt    DateTime?
  notifyChannel String?
  lineUserId    String?     // LINE User ID ของลูกค้า (จาก webhook)
  lineLinkedAt  DateTime?   // เวลาที่ลูกค้าลิงก์ LINE
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         ClaimItem[]

  @@map("insurance_claims")
}


model ClaimItem {
  id       String         @id @default(cuid())
  claimId  String
  partId   String?
  partName String
  quantity Int
  claim    InsuranceClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  part     Part?          @relation(fields: [partId], references: [id])

  @@map("claim_items")
}

model User {
  id        String          @id @default(cuid())
  username  String          @unique
  password  String
  name      String
  role      String          @default("admin")
  createdAt DateTime        @default(now())
  movements StockMovement[]

  @@map("users")
}

enum MovementType {
  IN
  OUT
}

enum ClaimStatus {
  PENDING
  ORDERED
  ARRIVED
  NOTIFIED
  COMPLETED
}

model LineRegistration {
  id              String   @id @default(cuid())
  lineUserId      String
  customerName    String
  plateNo         String
  normalizedPlate String
  matched         Boolean  @default(false)
  matchedClaimId  String?
  createdAt       DateTime @default(now())

  @@unique([lineUserId, normalizedPlate])
  @@map("line_registrations")
}
