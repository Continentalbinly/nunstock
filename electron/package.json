{
    "name": "nunmechanic-desktop",
    "version": "1.0.0",
    "description": "นันการช่าง - ระบบจัดการอะไหล่ร้านซ่อมรถยนต์",
    "main": "main.js",
    "author": "NunMechanic",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Continentalbinly/nunstock.git"
    },
    "scripts": {
        "start": "electron .",
        "build:win": "electron-builder --win --x64",
        "build:mac": "electron-builder --mac",
        "build:linux": "electron-builder --linux"
    },
    "dependencies": {
        "electron-updater": "^6.3.9"
    },
    "devDependencies": {
        "electron": "^33.3.1",
        "electron-builder": "^25.1.8"
    },
    "build": {
        "appId": "com.nunmechanic.desktop",
        "productName": "นันการช่าง",
        "directories": {
            "output": "dist"
        },
        "files": [
            "main.js",
            "preload.js",
            "icon.png"
        ],
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "icon.png",
            "artifactName": "NunMechanic-Setup-${version}.${ext}"
        },
        "nsis": {
            "oneClick": false,
            "perMachine": true,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "นันการช่าง",
            "installerIcon": "icon.png",
            "uninstallerIcon": "icon.png",
            "installerHeaderIcon": "icon.png",
            "installerSidebar": null,
            "license": "LICENSE.txt",
            "deleteAppDataOnUninstall": true,
            "runAfterFinish": true,
            "installerLanguages": [
                "English",
                "Thai"
            ]
        },
        "mac": {
            "target": "dmg",
            "icon": "icon.png",
            "category": "public.app-category.business"
        },
        "linux": {
            "target": "AppImage",
            "icon": "icon.png"
        },
        "publish": {
            "provider": "github",
            "releaseType": "release"
        }
    }
}